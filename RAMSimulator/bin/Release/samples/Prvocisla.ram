// Loads number
READ 1
LOAD 1

// Initilizes counter
SUB =1
STORE 2

loop:
// x = ((n/i)*i)-n 
LOAD 1
DIV 2
MULT 2
SUB 1
// x = 0
JZERO noprime

// Condition of loop end
LOAD 2
SUB =1
STORE 2
SUB =1
JGTZ loop

// Is a prime number
WRITE 1
ACCEPT
JUMP end

// Is not a prime number
noprime:
WRITE 0
REJECT
end:
HALT